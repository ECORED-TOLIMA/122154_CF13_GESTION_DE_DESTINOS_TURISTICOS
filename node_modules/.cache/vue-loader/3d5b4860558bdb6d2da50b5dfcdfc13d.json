  { id: 'a', texto: 'Falso', esCorrecta: false },\n            { id: 'b', texto: 'Verdadero', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 2,\n          texto:\n            'El monitoreo es esencial en la gestión turística, porque ayuda a ajustar estrategias en tiempo real para mejorar la experiencia de los visitantes.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: false },\n            { id: 'b', texto: 'Verdadero', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 3,\n          texto:\n            'La gestión turística no necesita el monitoreo constante, ya que los cambios en el sector no suelen ser significativos.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: true },\n            { id: 'b', texto: 'Verdadero', esCorrecta: false },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 4,\n          texto:\n            'El monitoreo es un proceso más amplio y complejo que la evaluación.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: true },\n            { id: 'b', texto: 'Verdadero', esCorrecta: false },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 5,\n          texto:\n            'La evaluación se realiza solo al final de un proyecto para determinar sus resultados e impactos.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: true },\n            { id: 'b', texto: 'Verdadero', esCorrecta: false },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 6,\n          texto:\n            'Las buenas prácticas en el monitoreo turístico incluyen la participación activa de la comunidad local.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: false },\n            { id: 'b', texto: 'Verdadero', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 7,\n          texto:\n            'El uso de tecnologías de monitoreo puede no ser indispensable cuando se dispone de suficiente personal en campo.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: true },\n            { id: 'b', texto: 'Verdadero', esCorrecta: false },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 8,\n          texto:\n            'Los enfoques metodológicos en el monitoreo turístico, varían según el tipo de destino y los objetivos específicos.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: false },\n            { id: 'b', texto: 'Verdadero', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 9,\n          texto:\n            'Los enfoques participativos no son útiles en el monitoreo turístico, porque dificultan la recolección de datos imparciales.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: true },\n            { id: 'b', texto: 'Verdadero', esCorrecta: false },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 10,\n          texto:\n            'La estacionalidad es un factor que afecta la demanda turística, ya que ciertos destinos reciben más visitantes en temporadas específicas del año.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: false },\n            { id: 'b', texto: 'Verdadero', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 11,\n          texto:\n            'Las herramientas tecnológicas como sensores y sistemas GIS pueden facilitar el monitoreo de áreas naturales.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: false },\n            { id: 'b', texto: 'Verdadero', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 12,\n          texto:\n            'Las tecnologías de monitoreo siempre son costosas y difíciles de implementar en destinos turísticos pequeños.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: true },\n            { id: 'b', texto: 'Verdadero', esCorrecta: false },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 13,\n          texto:\n            'Los indicadores de gestión pueden ser económicos, sociales y ambientales, cada uno midiendo diferentes aspectos del desarrollo turístico.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: false },\n            { id: 'b', texto: 'Verdadero', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 14,\n          texto:\n            'Todos los indicadores de gestión turística deben ser cuantitativos para asegurar la precisión de los datos.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: true },\n            { id: 'b', texto: 'Verdadero', esCorrecta: false },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 15,\n          texto:\n            'Los indicadores ambientales son fundamentales para evaluar el impacto ecológico del turismo en un destino.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: false },\n            { id: 'b', texto: 'Verdadero', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 16,\n          texto:\n            'El monitoreo puede identificar tanto impactos positivos como negativos del turismo en un destino.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: false },\n            { id: 'b', texto: 'Verdadero', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 17,\n          texto:\n            'Los métodos cuantitativos incluyen encuestas y análisis estadísticos para interpretar los datos de monitoreo.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: false },\n            { id: 'b', texto: 'Verdadero', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 18,\n          texto:\n            'Un informe final de monitoreo resume los hallazgos clave y recomienda acciones a seguir.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: false },\n            { id: 'b', texto: 'Verdadero', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 19,\n          texto:\n            'La mejora continua implica ajustar estrategias basadas en los resultados obtenidos del monitoreo.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: false },\n            { id: 'b', texto: 'Verdadero', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 20,\n          texto:\n            'Las estrategias turísticas no necesitan ser revisadas una vez implementadas si el monitoreo inicial fue riguroso.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Falso', esCorrecta: true },\n            { id: 'b', texto: 'Verdadero', esCorrecta: false },\n          ],\n          mensaje_correcto:\n            'Excelente trabajo. Tiene un claro entendimiento sobre el uso de indicadores de gestión turística.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n  