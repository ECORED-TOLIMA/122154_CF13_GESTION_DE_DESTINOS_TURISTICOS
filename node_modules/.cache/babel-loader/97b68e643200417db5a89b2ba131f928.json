rs:{\"src\":require(\"@/assets/curso/temas/ico.svg\"),\"alt\":\"Imagen decorativa\"}}),_c('h4',{staticClass:\"mb-0\"},[_vm._v(\"Adaptación a las necesidades del mercado\")])])\n},function (){var _vm=this,_c=_vm._self._c;return _c('div',{staticClass:\"row justify-content-center mb-5\",attrs:{\"data-aos\":\"flip-up\"}},[_c('div',{staticClass:\"col-lg-6 col-12 order-lg-2 order-2\"},[_c('p',[_vm._v(\"La retroalimentación de los turistas y de la comunidad local ayuda a los destinos a adaptarse a las cambiantes preferencias y necesidades del mercado. En un entorno dinámico como el turismo, la capacidad de respuesta a las tendencias emergentes es vital para la sostenibilidad a largo plazo. Un ejemplo de esto es la transformación de San Andrés, donde la demanda de turismo ecológico ha impulsado la creación de experiencias centradas en el buceo responsable y la conservación marina, ajustando la oferta turística para alinearse con el interés creciente por el turismo sostenible.\")])]),_c('div',{staticClass:\"col-lg-6 col-md-8 col-10 order-lg-1 order-1 mb-lg-0 mb-4\"},[_c('figure',[_c('img',{attrs:{\"src\":require(\"@/assets/curso/temas/tema7/img09.png\"),\"alt\":\"Imagen decorativa\"}})])])])\n},function (){var _vm=this,_c=_vm._self._c;return _c('div',{staticClass:\"titulo mb-5\",attrs:{\"data-aos\":\"flip-up\"}},[_c('img',{attrs:{\"src\":require(\"@/assets/curso/temas/ico.svg\"),\"alt\":\"Imagen decorativa\"}}),_c('h4',{staticClass:\"mb-0\"},[_vm._v(\"Involucramiento de la comunidad\")])])\n},function (){var _vm=this,_c=_vm._self._c;return _c('div',{staticClass:\"row justify-content-center mb-4\",attrs:{\"data-aos\":\"flip-up\"}},[_c('div',{staticClass:\"col-lg-6 col-12 order-lg-2 order-2\"},[_c('p',[_vm._v(\"La retroalimentación fomenta la participación de la comunidad en el proceso de toma de decisiones sobre el desarrollo turístico. Esto no solo ayuda a construir un sentido de pertenencia y orgullo local, sino que también asegura que el desarrollo turístico respete y preserve la cultura y los recursos naturales de la zona. Por ejemplo, en el Eje Cafetero, la opinión de los caficultores y comunidades locales ha sido clave para diseñar experiencias auténticas, como rutas del café que combinan educación, sostenibilidad y tradición. Gracias a esta retroalimentación, se han desarrollado prácticas turísticas responsables que benefician tanto a los visitantes como a los habitantes, generando un impacto positivo en la economía y el medio ambiente.\")])]),_c('div',{staticClass:\"col-lg-6 col-md-8 col-10 order-lg-1 order-1 mb-lg-0 mb-4\"},[_c('figure',[_c('img',{attrs:{\"src\":require(\"@/assets/curso/temas/tema7/img10.png\"),\"alt\":\"Imagen decorativa\"}})])])])\n}]\n\nexport { render, staticRenderFns }"],"mappings":"AAAA,IAAIA,MAAM,GAAG,SAASA,MAAMA,CAAA,EAAE;EAAC,IAAIC,GAAG,GAAC,IAAI;IAACC,EAAE,GAACD,GAAG,CAACE,KAAK,CAACD,EAAE;EAAC,OAAOA,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAA2B,CAAC,EAAC,CAACF,EAAE,CAAC,eAAe,CAAC,EAACA,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAAmD,CAAC,EAAC,CAACH,GAAG,CAACI,EAAE,CAAC,CAAC,CAAC,EAACJ,GAAG,CAACI,EAAE,CAAC,CAAC,CAAC,EAACH,EAAE,CAAC,WAAW,CAAC,EAACD,GAAG,CAACI,EAAE,CAAC,CAAC,CAAC,EAACH,EAAE,CAAC,GAAG,EAAC;IAACE,WAAW,EAAC,MAAM;IAACE,KAAK,EAAC;MAAC,UAAU,EAAC;IAAW;EAAC,CAAC,EAAC,CAACL,GAAG,CAACM,EAAE,CAAC,+JAA+J,CAAC,CAAC,CAAC,EAACL,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC,oDAAoD;IAACE,KAAK,EAAC;MAAC,UAAU,EAAC;IAAS;EAAC,CAAC,EAAC,CAACJ,EAAE,CAAC,SAAS,EAAC;IAACI,KAAK,EAAC;MAAC,UAAU,EAAC;IAAmB;EAAC,CAAC,EAAC,CAACJ,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAA2B,CAAC,EAAC,CAACF,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAAiC,CAAC,EAAC,CAACF,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAAyB,CAAC,EAAC,CAACF,EAAE,CAAC,KAAK,EAAC;IAACI,KAAK,EAAC;MAAC,KAAK,EAACE,OAAO,CAAC,sCAAsC,CAAC;MAAC,KAAK,EAAC;IAAW;EAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAACN,EAAE,CAAC,IAAI,EAAC;IAACE,WAAW,EAAC;EAAa,CAAC,EAAC,CAACH,GAAG,CAACM,EAAE,CAAC,sCAAsC,CAAC,CAAC,CAAC,EAACL,EAAE,CAAC,GAAG,EAAC,CAACD,GAAG,CAACM,EAAE,CAAC,gJAAgJ,CAAC,CAAC,CAAC,CAAC,CAAC,EAACL,EAAE,CAAC,KAAK,EAAC